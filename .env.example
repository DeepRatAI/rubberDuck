APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgres://devit:devit@localhost:5432/devit
AUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
# Set true in CI/deploy checks to fail fast when production-critical env is missing.
RUBBERDUCK_STRICT_ENV=false
# Local-only Playwright mode for `next start` E2E. Never set on preview/production URLs.
RUBBERDUCK_E2E_MODE=false
# Backwards-compatible alias during the rebrand; prefer RUBBERDUCK_STRICT_ENV.
DEVIT_STRICT_ENV=false
GITHUB_ID=
GITHUB_SECRET=
# Optional GitHub API token for Project Signal repository preview/enrichment rate limits.
GITHUB_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=
EMAIL_FROM=
# Vercel Cron sends Authorization: Bearer $CRON_SECRET when configured.
# RSS_REFRESH_SECRET can be omitted if CRON_SECRET is set to the same value.
CRON_SECRET=local-rss-refresh-secret
RSS_REFRESH_SECRET=local-rss-refresh-secret
STORAGE_DRIVER=local
NEXT_PUBLIC_DEFAULT_LOCALE=en
ADMIN_EMAILS=

# PostHog analytics. The token is public by design.
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare Turnstile. Site key is public; secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional rate-limit/cache provider.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional observability.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Course media storage. For Cloudflare R2 set STORAGE_DRIVER=r2 and fill all R2 vars.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Optional Vercel Blob fallback, not used by the active adapter yet.
BLOB_READ_WRITE_TOKEN=
